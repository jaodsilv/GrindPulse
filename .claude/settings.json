{
  "hooks": {
    "UserPromptExpansion": [
      {
        "matcher": "process-list",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/process_list_hook.py"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/agent_dispatch.py"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "matcher": "solutions-parser|coding-challenge-solver|community-time-finder|code-explanator|solution-analyzer|justification-criticizer|time-selection",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/subagent_start.py"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "community-time-finder",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/subagent_stop_community_finder.py"
          }
        ]
      },
      {
        "matcher": "solutions-parser|coding-challenge-solver|community-time-finder|code-explanator|solution-analyzer|justification-criticizer|time-selection",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/subagent_stop_state_advance.py"
          }
        ]
      },
      {
        "matcher": "time-selection",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/subagent_stop_time_selection.py"
          }
        ]
      }
    ]
  }
}
